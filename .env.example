# Sika Sentinel — environment variables
# Copy to .env and fill in real values before running.
# NEVER commit .env to version control.

# ── Hedera Network ────────────────────────────────────────────────────────────
HEDERA_NETWORK=testnet                   # testnet | mainnet

# Operator account (pays all transaction fees)
HEDERA_OPERATOR_ID=0.0.XXXXXX
HEDERA_OPERATOR_KEY=302e...             # ED25519 DER-encoded private key

# Treasury / payout source account
HEDERA_TREASURY_ID=0.0.XXXXXX
HEDERA_TREASURY_KEY=302e...

# Demo approved recipient (partner wallet)
HEDERA_RECIPIENT_ID=0.0.XXXXXX

# HCS audit topic — run scripts/create_topic.py once to generate this
HCS_TOPIC_ID=0.0.XXXXXX

# Mirror node base URL (default: Hedera public testnet mirror)
MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com

# ── LLM (intent parsing) ──────────────────────────────────────────────────────
# Provide whichever key matches your LangChain provider in requirements.txt
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

LLM_MODEL=gpt-4o                        # or claude-sonnet-4-6 if using Anthropic

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
